# SocialLab RSS agent
RSS_URL=https://sociallab.ai/feed/
# Or a comma-separated list:
# RSS_URLS=https://sociallab.ai/feed/,https://sociallab.ai/category/news/feed/
# Option 1: Supabase REST access (recommended)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Option 2: Direct PostgreSQL access
DATABASE_URL=postgresql://USER:***@HOST:5432/DBNAME
TABLE_NAME=sociallab_rss_items
MAX_ITEMS=100
DRY_RUN=1
# For local Postgres you can disable TLS:
# PGSSLMODE=disable
